{
  "expo": {
    "name": "CureMate",
    "slug": "CureMate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/CureMate_logo.png",
    "scheme": "curemate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5B4BE0",
        "foregroundImage": "./assets/images/CureMate_logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ivy_porcado.CureMate"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/CureMate_logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#5B4BE0",
          "dark": {
            "backgroundColor": "#5B4BE0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1eb8e26-d828-4d1e-8c50-c67bf557a2a2"
      }
    }
  }
}
